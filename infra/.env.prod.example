# File:    infra/.env.prod.example
# Purpose: Template for the production env file. Copy to `.env.prod` on the
#          VPS (chmod 600) and fill in real values. NEVER commit `.env.prod`.
# Owner:   Navanish (Phase 5)
#
# Loaded by:
#   - docker-compose.prod.yml (via --env-file infra/.env.prod)
#   - each service's `env_file` directive picks up DJANGO_SECRET_KEY,
#     DATABASE_URL, AI_SERVICE_INTERNAL_KEY, GEMINI_API_KEY, etc.

# ── Image tags ────────────────────────────────────────────────────────────────
# Defaults to :latest. Pin to a SHA tag for a deterministic deploy:
#   BACKEND_IMAGE=ghcr.io/amfire-tech/skillship_test-backend:a1b2c3d
BACKEND_IMAGE=ghcr.io/amfire-tech/skillship_test-backend:latest
AI_SERVICE_IMAGE=ghcr.io/amfire-tech/skillship_test-ai-service:latest
FRONTEND_IMAGE=ghcr.io/amfire-tech/skillship_test-frontend:latest

# ── Django backend ────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-with-64-random-bytes
DJANGO_ALLOWED_HOSTS=skillship.example.com,www.skillship.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://skillship.example.com,https://www.skillship.example.com

# Supabase (or any managed Postgres + pgvector) — the pooler URL.
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# REDIS_URL is hard-coded to redis://redis:6379/0 by compose; do not override here.

# ── Internal AI service auth ─────────────────────────────────────────────────
# A long random string. Must match across backend + ai-service env files.
AI_SERVICE_INTERNAL_KEY=replace-with-32-random-bytes

# ── AI service (FastAPI) ─────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...your-real-key
MODEL_NAME=gemini-2.5-flash
EMBEDDING_MODEL=models/text-embedding-004
# pgvector URL — usually the same Supabase database as DATABASE_URL above.
PGVECTOR_URL=postgresql://postgres.xxxx:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
LOG_LEVEL=INFO

# ── Frontend build-time env (set as repo VARIABLE in GitHub, not here) ──────
# NEXT_PUBLIC_API_BASE_URL is BAKED INTO the frontend image at `docker build`
# time. The CI workflow reads it from `vars.NEXT_PUBLIC_API_BASE_URL` (a
# repo-level Variable, not Secret). Setting it here has no effect.
#
# Variable to set on GitHub:
#   NEXT_PUBLIC_API_BASE_URL=https://skillship.example.com/api/v1

# ── Sentry (deferred until phase 6 / post-launch) ─────────────────────────
# SENTRY_DSN_BACKEND=
# SENTRY_DSN_AI_SERVICE=
